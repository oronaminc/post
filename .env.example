# 이 파일을 .env 로 복사한 뒤 값을 채우세요 (`.env` 는 git에 커밋되지 않습니다).
#
# YouTube Data API v3 키 (무료).
# 발급: https://console.cloud.google.com/ → "YouTube Data API v3" 사용 설정 → API 키 생성
# 키가 없으면 YouTube 어댑터는 자동으로 건너뜁니다(graceful).
YOUTUBE_API_KEY=

# 네이버 API (NCP API Hub) — 한국 소스: 네이버 뉴스 검색 + 데이터랩 검색어트렌드.
# 2024년 이후 네이버 Open API 는 NCP API Hub 로 이관됨.
# 발급/활성화: https://www.ncloud.com → 콘솔 → Services → AI·NAVER API / API Hub
#   → 애플리케이션 등록 → '검색(뉴스)' 와 '데이터랩(검색어트렌드)' API 를 각각 활성화/구독
#   → 인증정보의 Client ID / Client Secret 복사.
# 키가 없거나 API 미활성 시 네이버 소스만 헬스에 오류로 표시되고 나머지는 정상 동작합니다.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# (선택) config.yaml 경로를 덮어쓰고 싶을 때
# APP_CONFIG=./config.yaml
